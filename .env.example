# WhatsApp Reply Copilot — environment variables
# This MVP runs fully offline with rule-based logic and does not require any keys.
# These placeholders are reserved for future integrations.

# Optional: LLM provider key, used only if/when reply_engine swaps to an LLM.
OPENAI_API_KEY=

# Optional: Ara / OpenClaw agent endpoint and credentials for the next milestone.
ARA_API_BASE=
ARA_API_KEY=

# Optional: WhatsApp channel identifier once Ara QR pairing is connected.
ARA_WHATSAPP_CHANNEL_ID=
